{
  "name": "poke-plaid-mcp",
  "version": "1.0.0",
  "description": "MCP server that exposes your Plaid-linked investment portfolio (holdings, balances, dividends) to Poke.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "poke-plaid-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/public','dist/public',{recursive:true})\"",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "link:sandbox": "tsx scripts/sandbox-link.ts",
    "test:mcp": "tsx scripts/test-mcp.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "plaid": "^43.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
