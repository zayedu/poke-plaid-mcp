# ---------------------------------------------------------------------------
# poke-plaid-mcp configuration
# Copy this file to `.env` and fill in your values.
# ---------------------------------------------------------------------------

# --- Server ---------------------------------------------------------------
# Port the HTTP/MCP server listens on.
PORT=3000

# Interface to bind. Defaults to 127.0.0.1 (loopback) so a local install is
# never exposed to your LAN — this still works with `poke tunnel`. Set to
# 0.0.0.0 ONLY when deploying to a container/host (Docker, Render, etc.).
HOST=127.0.0.1

# development | production. In production the server refuses to start if it is
# bound to a public interface without MCP_API_KEY, or uses Plaid without
# TOKEN_ENCRYPTION_KEY.
NODE_ENV=development

# Public base URL of this server (used by the Plaid Link setup page and to build
# the Host/Origin allowlist). Set it to your tunnel/host URL when deploying.
PUBLIC_BASE_URL=http://localhost:3000

# Bearer token Poke must send to call this MCP server (sent as
# `Authorization: Bearer <key>`). REQUIRED for any internet-facing deployment.
# Leave blank only for a purely local tunnel.
MCP_API_KEY=

# --- Access control -------------------------------------------------------
# Token required to use the /setup routes (Plaid linking). REQUIRED to expose
# setup on a public host; locally you can leave it blank. Pass it as
# ?token=... in the setup URL.
SETUP_TOKEN=

# Extra comma-separated hosts/origins to allow (DNS-rebinding protection).
# PUBLIC_BASE_URL and loopback are always allowed. Usually leave blank.
ALLOWED_HOSTS=
ALLOWED_ORIGINS=

# Set to true to disable Host-header allowlisting (e.g. behind a proxy that
# rewrites Host). Only do this if you understand the risk. Origin checks stay on.
ALLOW_ANY_HOST=false

# --- Plaid ----------------------------------------------------------------
# Get these from https://dashboard.plaid.com  (Developers -> Keys)
# Leave PLAID_CLIENT_ID / PLAID_SECRET blank to run in MOCK mode with
# realistic sample data (great for wiring up Poke before you have Plaid keys).
PLAID_CLIENT_ID=
PLAID_SECRET=

# One of: sandbox | production
PLAID_ENV=sandbox

# Comma-separated Plaid products to request during Link. `investments` is
# required for portfolio tracking; `transactions` is optional.
PLAID_PRODUCTS=investments

# Comma-separated country codes for Link (e.g. US, CA). Wealthsimple is CA.
PLAID_COUNTRY_CODES=US,CA

# Human-friendly name shown in the Plaid Link UI.
PLAID_APP_NAME=Poke Portfolio

# --- Storage --------------------------------------------------------------
# Where linked-item access tokens are persisted (JSON, encrypted at rest).
TOKEN_STORE_PATH=./data/items.json

# 32+ char secret used to encrypt access tokens on disk. If blank, tokens are
# stored obfuscated but NOT strongly encrypted — set this in production.
TOKEN_ENCRYPTION_KEY=
